generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "curriculumai"]
}

// ── Auth ───────────────────────────────────────────────────────────────────

model AuthUser {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email              String    @unique
  passwordHash       String    @map("password_hash")
  rawUserMetaData    Json      @default("{}") @map("raw_user_meta_data")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile            Profile?

  @@map("users")
  @@schema("auth")
}

// ── curriculumai ──────────────────────────────────────────────────────────

model Profile {
  id            String             @id @db.Uuid
  fullName      String             @map("full_name")
  email         String             @unique
  phone         String?
  nationality   String?
  birthDate     DateTime?          @map("birth_date") @db.Date
  institution   String?
  department    String?
  academicLevel AcademicLevelEnum? @map("academic_level")
  bio           String?
  profilePhoto  String?            @map("profile_photo")
  linkedinUrl   String?            @map("linkedin_url")
  orcidId       String?            @map("orcid_id")
  websiteUrl    String?            @map("website_url")
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          AuthUser           @relation(fields: [id], references: [id], onDelete: Cascade)
  curriculums   Curriculum[]
  education     Education[]
  experiences   Experience[]
  publications  Publication[]
  projects      Project[]
  certifications Certification[]
  skills        Skill[]
  languages     Language[]
  awards        Award[]
  references    Reference[]
  generatedCvs  GeneratedCv[]
  aiLogs        AiLog[]

  @@map("profiles")
  @@schema("curriculumai")
}

model Curriculum {
  id           String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  title        String
  summary      String?
  templateName TemplateEnum @default(academic) @map("template_name")
  language     String       @default("pt")
  aiGenerated  Boolean      @default(false) @map("ai_generated")
  isPublic     Boolean      @default(false) @map("is_public")
  isDefault    Boolean      @default(false) @map("is_default")
  viewCount    Int          @default(0) @map("view_count")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile      Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedCvs GeneratedCv[]

  @@map("curriculums")
  @@schema("curriculumai")
}

model Education {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  institution  String
  degree       String
  fieldOfStudy String?   @map("field_of_study")
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  isCurrent    Boolean   @default(false) @map("is_current")
  grade        String?
  description  String?
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile      Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("education")
  @@schema("curriculumai")
}

model Experience {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  organization String
  role         String
  location     String?
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  isCurrent    Boolean   @default(false) @map("is_current")
  description  String?
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile      Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("experiences")
  @@schema("curriculumai")
}

model Publication {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  title           String
  authors         String?
  journal         String?
  publicationDate DateTime? @map("publication_date") @db.Date
  doi             String?
  url             String?
  abstract        String?
  pubType         String    @default("article") @map("pub_type")
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile         Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("publications")
  @@schema("curriculumai")
}

model Project {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  title         String
  description   String?
  role          String?
  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  isCurrent     Boolean   @default(false) @map("is_current")
  fundingEntity String?   @map("funding_entity")
  budget        Decimal?  @db.Decimal(14, 2)
  url           String?
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile       Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
  @@schema("curriculumai")
}

model Certification {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  name                String
  issuingOrganization String?   @map("issuing_organization")
  issueDate           DateTime? @map("issue_date") @db.Date
  expiryDate          DateTime? @map("expiry_date") @db.Date
  credentialId        String?   @map("credential_id")
  credentialUrl       String?   @map("credential_url")
  sortOrder           Int       @default(0) @map("sort_order")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile             Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certifications")
  @@schema("curriculumai")
}

model Skill {
  id               String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String               @map("user_id") @db.Uuid
  skillName        String               @map("skill_name")
  category         String?
  proficiencyLevel ProficiencyLevelEnum? @map("proficiency_level")
  sortOrder        Int                  @default(0) @map("sort_order")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  profile          Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("skills")
  @@schema("curriculumai")
}

model Language {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  language    String
  proficiency String    @default("intermediario")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile     Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("languages")
  @@schema("curriculumai")
}

model Award {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  title       String
  issuer      String?
  awardDate   DateTime? @map("award_date") @db.Date
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile     Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("awards")
  @@schema("curriculumai")
}

model Reference {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  name         String
  title        String?
  organization String?
  email        String?
  phone        String?
  isVisible    Boolean   @default(false) @map("is_visible")
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile      Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("references")
  @@schema("curriculumai")
}

model GeneratedCv {
  id            String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  curriculumId  String     @map("curriculum_id") @db.Uuid
  fileUrl       String?    @map("file_url")
  fileSizeBytes Int?       @map("file_size_bytes")
  generatedByAi Boolean    @default(true) @map("generated_by_ai")
  expiresAt     DateTime?  @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  profile       Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  curriculum    Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  @@map("generated_cvs")
  @@schema("curriculumai")
}

model AiLog {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  action     String
  prompt     String?
  response   String?
  model      String    @default("gemini-1.5-flash")
  tokensUsed Int?      @map("tokens_used")
  durationMs Int?      @map("duration_ms")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile    Profile?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("ai_logs")
  @@schema("curriculumai")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum AcademicLevelEnum {
  licenciatura
  mestrado
  doutoramento
  pos_doutoramento
  professor
  investigador
  outro

  @@map("academic_level_enum")
  @@schema("curriculumai")
}

enum ProficiencyLevelEnum {
  basico
  intermediario
  avancado
  especialista

  @@map("proficiency_level_enum")
  @@schema("curriculumai")
}

enum TemplateEnum {
  academic
  research
  industry
  minimal

  @@map("template_enum")
  @@schema("curriculumai")
}
